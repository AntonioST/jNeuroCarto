#! /bin/bash

VERSION_javafx=26
VERSION_picocli=4.7.7
VERSION_slf4j=2.0.17

M=$HOME/.m2/repository
read -d '' -r CP << EOF
$M/info/picocli/picocli/$VERSION_picocli/picocli-$VERSION_picocli.jar
$M/org/openjfx/javafx-base/$VERSION_javafx/javafx-base-$VERSION_javafx.jar
$M/org/openjfx/javafx-base/$VERSION_javafx/javafx-base-$VERSION_javafx-linux.jar
$M/org/openjfx/javafx-controls/$VERSION_javafx/javafx-controls-$VERSION_javafx.jar
$M/org/openjfx/javafx-controls/$VERSION_javafx/javafx-controls-$VERSION_javafx-linux.jar
$M/org/openjfx/javafx-graphics/$VERSION_javafx/javafx-graphics-$VERSION_javafx.jar
$M/org/openjfx/javafx-graphics/$VERSION_javafx/javafx-graphics-$VERSION_javafx-linux.jar
$M/org/slf4j/slf4j-api/$VERSION_slf4j/slf4j-api-$VERSION_slf4j.jar
$M/org/slf4j/slf4j-simple/$VERSION_slf4j/slf4j-simple-$VERSION_slf4j.jar
../jNeuroCarto-core/target/classes
target/classes
EOF

archlinux-java-run --min 26 -- \
    --enable-preview \
    --enable-native-access=javafx.graphics \
    --add-modules=info.picocli \
    -Dorg.slf4j.simpleLogger.defaultLogLevel=warn \
    -p $(echo $CP | tr ' ' ':') \
    -m io.ast.jneurocarto.javafx.chart/io.ast.jneurocarto.javafx.chart.cli.Main \
    "$@"
